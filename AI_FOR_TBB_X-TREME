local DeployRemote = ReplicatedStorage:FindFirstChild("DeployUnit") or ReplicatedStorage:FindFirstChild("SpawnUnit") or ReplicatedStorage:FindFirstChild("Summon")
local UpgradeRemote = ReplicatedStorage:FindFirstChild("UpgradeInvestment") or ReplicatedStorage:FindFirstChild("Upgrade_Investment") or ReplicatedStorage:FindFirstChild("UpgradeUnit") or ReplicatedStorage:FindFirstChild("UpgradeBank")
local GatlingRemote = ReplicatedStorage:FindFirstChild("UseGatling") or ReplicatedStorage:FindFirstChild("Gatling") or ReplicatedStorage:FindFirstChild("UseAbility")
local RestartRemote = ReplicatedStorage:FindFirstChild("Restart") or ReplicatedStorage:FindFirstChild("RestartMatch") or ReplicatedStorage:FindFirstChild("Retry")

local function spawnUnit(unitName)
    if tick() - lastActionTime < ACTION_COOLDOWN then return false end
    if DeployRemote then
        lastActionTime = tick()
        if DeployRemote:IsA("RemoteEvent") then DeployRemote:FireServer(unitName) end
        return true
    end
    return false
end

local function upgradeTech(techName)
    if tick() - lastActionTime < ACTION_COOLDOWN then return false end
    if UpgradeRemote then
        lastActionTime = tick()
        if UpgradeRemote:IsA("RemoteEvent") then UpgradeRemote:FireServer(techName) end
        return true
    end
    return false
end

local function useGatling()
    if GatlingRemote and GatlingRemote:IsA("RemoteEvent") then GatlingRemote:FireServer("Gatling") end
end

local function getCash()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats and leaderstats:FindFirstChild("Cash") then return leaderstats.Cash.Value end
    return 0
end

local function findEntity(name, exactCount)
    local count = 0 local lastFound = nil
    local folders = {Workspace, Workspace:FindFirstChild("Enemies"), Workspace:FindFirstChild("Friendly"), Workspace:FindFirstChild("Units")}
    for _, folder in pairs(folders) do
        if folder then
            for _, child in pairs(folder:GetChildren()) do
                if child.Name and string.find(string.lower(child.Name), string.lower(name)) then
                    count = count + 1 lastFound = child
                end
            end
        end
    end
    if exactCount then return count end
    return lastFound
end

-- ЗАЦИКЛЕННЫЙ УМНЫЙ ГАТЛИНГ (Твои триггеры на деатмарки и взрыв Вархеада)
local function checkSmartGatlingУсловия()
    if not isAutoMode or isThinking then return end
    local infernus = findEntity("Infernus")
    if infernus then
        local marks = 0
        for _, obj in pairs(infernus:GetDescendants()) do
            if obj.Name and (string.find(string.lower(obj.Name), "mark") or string.find(string.lower(obj.Name), "death")) then
                marks = marks + 1
            end
        end
        if marks >= 2 then
            useGatling()
            Rayfield:Notify({Title = "🔥 СЕЙВ ИНФЕРНУСА!", Content = "У него 2 деатмарка! Спасаю Гатлингом!", Duration = 3})
            return
        end
    end
    local warhead = findEntity("Warhead")
    if warhead then
        local isExploding = warhead:FindFirstChild("Exploding") or warhead:FindFirstChild("Charge") or (warhead:FindFirstChild("Humanoid") and warhead.Humanoid.Health < 500)
        if isExploding then
            useGatling()
            Rayfield:Notify({Title = "🚨 ФИНАЛЬНЫЙ СНОС!", Content = "Вархеад взрывается! Добиваю Гатлингом!", Duration = 3})
        end
    end
end

-- СКАНИРОВАНИЕ И РАСЧЕТ ПИКА СИЛЫ (Твоя формула эффективности)
local function evaluateCurrentEfficiency()
    if not isAutoMode or isThinking or not matchStartTime then return end
    local base = Workspace:FindFirstChild("Base") or Workspace:FindFirstChild("MainCore") or Workspace:FindFirstChild("Core")
    if not base or not base:FindFirstChild("Humanoid") then return end
    
    local hpPercent = base.Humanoid.Health / base.Humanoid.MaxHealth
    local ourUnits = findEntity("Trowel", true) + findEntity("Infernus", true) + findEntity("Atari", true) + findEntity("Rail", true)
    local enemyUnits = findEntity("Enemy", true) + findEntity("Cyber", true) + findEntity("Bloodhorn", true)
    
    local currentEfficiency = (hpPercent * 100) + (ourUnits * 10) - (enemyUnits * 15)
    local currentMatchTime = tick() - matchStartTime
    
    if currentEfficiency > currentRoundMaxEfficiency then
        currentRoundMaxEfficiency = currentEfficiency
        currentRoundBestTime = currentMatchTime
        currentRoundBestStage = currentStage
    end
end

task.spawn(function() while task.wait(1) do pcall(evaluateCurrentEfficiency) end end)
