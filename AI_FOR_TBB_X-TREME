-- ПОШАГОВЫЙ БОЕВОЙ ЦИКЛ HEARTBEAT (ТВОЯ ИДЕАЛЬНАЯ СТРАТЕГИЯ С КАРТИНКИ)
_G.TBB_AI_Connected = RunService.Heartbeat:Connect(function()
    if not isAutoMode or isThinking then return end
    
    if not matchStartTime then matchStartTime = tick() end
    
    local myCash = getCash()
    local timePassed = tick() - matchStartTime
    
    -- Проверка триггеров на умный Гатлинг каждый кадр
    checkSmartGatlingУсловия()
    
    -- Оптимизированное обновление интерфейсов раз в 0.2 сек (защита от лагов)
    if tick() - lastUiUpdateTime > 0.2 then
        lastUiUpdateTime = tick()
        
        StressLabel:Set("Текущий накопленный стресс системы: " .. _G.AI_Total_Stress .. "/15")
        OffsetLabel:Set(string.format("Адаптивный сдвиг: %.1f сек", _G.Infernus_Timing_Offset))
        BestMomentLabel:Set(string.format("Пик эффективности на: %d сек", math.floor(_G.AI_Best_Moment_Time)))
        BestStageLabel:Set("Стадия лучшего момента: " .. _G.AI_Best_Moment_Stage)
        
        if timePassed <= BOOT_UP_TIME then
            local timeLeft = math.max(0, math.floor(BOOT_UP_TIME - timePassed))
            TopBarText.Text = string.format("🔋 РАЗГОН ЭКОНОМИКИ (Босс спит): %d сек | Налик: $%d", timeLeft, myCash)
            TopBarText.TextColor3 = Color3.fromRGB(0, 255, 120)
        else
            local battleTime = timePassed - BOOT_UP_TIME
            local kaboomTime = math.max(0, TOTAL_MATCH_TIME - battleTime)
            local mins = math.floor(kaboomTime / 60)
            local secs = math.floor(kaboomTime % 60)
            
            if kaboomTime <= 60 then
                TopBarText.Text = string.format("🚨 СТРЕСС-ЭНДГЕЙМ! ДО КАБУМА: %02d:%02d | Шаг: %s | Налик: $%d", mins, secs, currentStage, myCash)
                TopBarText.TextColor3 = Color3.fromRGB(255, 30, 30)
                handleAiDefeat("Кабум близко", 10) -- Пребывание в последней минуте перед кабумом дает +10 стресса
            else
                TopBarText.Text = string.format("⚔️ ИИ В БОЮ | ДО КАБУМА: %02d:%02d | ШАГ: %s | $%d", mins, secs, currentStage, myCash)
                TopBarText.TextColor3 = Color3.fromRGB(255, 255, 255)
            end
        end
    end
    
    -- ВЫПОЛНЕНИЕ ШАГОВ
    if timePassed <= BOOT_UP_TIME then
        if currentStage == "Investment_4" then
            upgradeTech("Investment")
        end
    else
        if currentStage == "Investment_4" then
            currentStage = "Spawn_2_Trowels"
        end
        
        if currentStage == "Spawn_2_Trowels" then
            if findEntity("Trowel", true) < 2 then spawnUnit("Trowel") else currentStage = "Wait_Infernus_BG4" end
            
        elseif currentStage == "Wait_Infernus_BG4" then
            local bgNum = Workspace:FindFirstChild("BackgroundNumbers") or Workspace:FindFirstChild("BG_Numbers")
            local bgValue = bgNum and bgNum.Value or 4
            
            -- Применяем сдвиг обучения нейросети (Infernus_Timing_Offset)
            if (bgValue >= 4 or (tick() - matchStartTime) >= (BOOT_UP_TIME - _G.Infernus_Timing_Offset)) and myCash >= (basePrices.Lil_Infernus * PRICE_MULTIPLIER) then
                if spawnUnit("Lil_Infernus") then currentStage = "Bank_5" end
            end
            
        elseif currentStage == "Bank_5" then
            upgradeTech("Bank")
            if myCash >= (basePrices.Trowel * PRICE_MULTIPLIER) and findEntity("Trowel", true) < 4 then spawnUnit("Trowel")
            elseif findEntity("Trowel", true) >= 4 then currentStage = "Bank_6" end
            
        elseif currentStage == "Bank_6" then
            if upgradeTech("Bank") then currentStage = "Wait_Vigilante_Gatling" end
            
        elseif currentStage == "Wait_Vigilante_Gatling" then
            currentStage = "Bank_8" -- Гатлинг контролируется твоей умной функцией, идем дальше
            
        elseif currentStage == "Bank_8" then
            upgradeTech("Bank")
            if myCash >= 2800 then currentStage = "Cash_2800_Trowel" end
            
        elseif currentStage == "Cash_2800_Trowel" then
            if myCash >= (basePrices.Trowel * PRICE_MULTIPLIER) then
                spawnUnit("Trowel") upgradeTech("Bank") currentStage = "Wait_Expunger"
            end
            
        elseif currentStage == "Wait_Expunger" then
            local expunger = findEntity("Expunger")
            if expunger or myCash >= 3200 then spawnUnit("Trowel") currentStage = "Cash_3200_Infernus" end
            
        elseif currentStage == "Cash_3200_Infernus" then
            if myCash >= (basePrices.Lil_Infernus * PRICE_MULTIPLIER) then
                spawnUnit("Lil_Infernus") task.wait(0.4) spawnUnit("Trowel") task.wait(0.4) spawnUnit("Atari")
                currentStage = "Wait_CyberBattler_Death"
            end
            
        elseif currentStage == "Wait_CyberBattler_Death" then
            local cyber = findEntity("Cyber")
            if not cyber then spawnUnit("Prospect") currentStage = "Wait_Bloodhorn_Scream" end
            
        elseif currentStage == "Wait_Bloodhorn_Scream" then
            local bloodhorn = findEntity("Bloodhorn")
            local operatorExtremePrice = basePrices.Operator * PRICE_MULTIPLIER
            local atariExtremePrice = basePrices.Atari * PRICE_MULTIPLIER
            
            -- Твоя исправленная логика цен (Оператор строго на 3к!)
            if bloodhorn or myCash >= operatorExtremePrice then 
                if spawnUnit("Operator") then
                    task.wait(0.3)
                    if getCash() >= atariExtremePrice then
                        spawnUnit("Atari")
                    end
                    currentStage = "Late_Spam_Phase"
                end
            end
            
        elseif currentStage == "Late_Spam_Phase" then
            local enemiesCount = findEntity("Enemy", true) or findEntity("Cyber", true)
            
            if myCash >= (basePrices.Rail_Battler * PRICE_MULTIPLIER) then spawnUnit("Rail_Battler") end
            if myCash >= (basePrices.Prospect * PRICE_MULTIPLIER) then spawnUnit("Prospect") end
            
            -- Оценка ситуации: если врагов много — мясо, если мало — Атари
            if enemiesCount > 3 then
                spawnUnit("Trowel")
                spawnUnit("Conjuror")
            else
                spawnUnit("Atari")
            end
        end
    end
end)
