-- Процесс логической корректировки ДНК вокруг лучшего момента
local function runAITHINKINGProcess(stage)
    isThinking = true
    _G.TopBarText.TextColor3 = Color3.fromRGB(255, 120, 0)
    local totalTimeSurvived = tick() - matchStartTime
    
    Rayfield:Notify({Title = "🧠 АНАЛИЗ ЛУЧШЕГО МОМЕНТА", Content = "Поиск точки перелома боя и мутация ДНК...", Duration = 4})
    
    if currentRoundMaxEfficiency > _G.AI_Max_Match_Efficiency then
        _G.AI_Max_Match_Efficiency = currentRoundMaxEfficiency
        _G.AI_Best_Moment_Time = currentRoundBestTime
        _G.AI_Best_Moment_Stage = currentRoundBestStage
        _G.AI_Best_Infernus_Offset = _G.Infernus_Timing_Offset
        _G.TopBarText.Text = string.format("🧠 ИИ: Нашел лучший момент на %d-й сек! Запоминаем...", math.floor(currentRoundBestTime))
    else
        _G.TopBarText.Text = "🧠 ИИ: Текущий раунд слабее пика. Откат к лучшей тактике..."
        _G.Infernus_Timing_Offset = _G.AI_Best_Infernus_Offset
    end
    
    local timeDelta = totalTimeSurvived - currentRoundBestTime
    if timeDelta < 10 then
        ACTION_COOLDOWN = math.max(0.20, ACTION_COOLDOWN - 0.03) -- Резкий слив после пика силы
    else
        _G.Infernus_Timing_Offset = _G.Infernus_Timing_Offset - 1.5 -- Медленное увядание фронта
    end
    
    task.wait(3.5) -- Фаза глубокого удержания мысли в памяти
    currentRoundMaxEfficiency = 0
    currentRoundBestTime = 0
    
    -- Вызов сигнала рестарта матча
    if RestartRemote then
        RestartRemote:FireServer()
    else
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, btn in pairs(pGui:GetDescendants()) do
                if btn:IsA("TextButton") and (string.find(string.lower(btn.Name), "restart") or string.find(string.lower(btn.Text), "retry")) then
                    pcall(function() btn:MouseButton1Click() end)
                    break
                end
            end
        end
    end
    
    isThinking = false
    currentStage = "Investment_4"
    matchStartTime = tick()
end

-- Функция обработки паники и накопления стресса базы
local function handleAIDefeat(reason, stressPoints)
    if isThinking then return end
    _G.AI_Total_Stress = _G.AI_Total_Stress + stressPoints
    if _G.AI_Total_Stress >= 15 then
        _G.AI_Total_Stress = 0
        task.spawn(function() runAITHINKINGProcess(currentStage) end)
    end
end

