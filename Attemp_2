-- Функция безопасного деплоя юнитов с учетом кулдауна
local function spawnUnit(unitName)
    if tick() - lastActionTime < ACTION_COOLDOWN then return false end
    if DeployRemote then
        lastActionTime = tick()
        DeployRemote:FireServer(unitName)
        return true
    end
    return false
end

-- Функция прокачки банка/инвестиций
local function upgradeTech(techName)
    if tick() - lastActionTime < ACTION_COOLDOWN then return false end
    if UpgradeRemote then
        lastActionTime = tick()
        UpgradeRemote:FireServer(techName)
        return true
    end
    return false
end

-- Функция активации Гатлинга
local function useGatling()
    if GatlingRemote then 
        GatlingRemote:FireServer("Gatling") 
    end
end

-- Функция сканирования объектов на карте (Поиск врагов и союзников)
local function findEntity(name, exactCount)
    local count = 0 
    local lastFound = nil
    local folders = {
        Workspace:FindFirstChild("Enemies"), 
        Workspace:FindFirstChild("Friendly"), 
        Workspace:FindFirstChild("Units")
    }
    
    for _, folder in pairs(folders) do
        if folder then
            for _, child in pairs(folder:GetChildren()) do
                if child.Name and string.find(string.lower(child.Name), string.lower(name)) then
                    count = count + 1 
                    lastFound = child
                end
            end
        end
    end
    
    if exactCount then 
        return count 
    end
    return lastFound
end
