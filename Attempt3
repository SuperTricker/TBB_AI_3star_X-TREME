-- УМНЫЙ ГАТЛИНГ (ТРИГГЕРЫ НА ДЕАТМАРКИ ИЛИ ВЗРЫВ ВАРХЕАДА)
local function checkSmartGatlingУсловия()
    if not isAutoMode or isThinking then return end
    local infernus = findEntity("Infernus")
    if infernus then
        local marks = 0
        for _, obj in pairs(infernus:GetDescendants()) do
            if obj.Name and (string.find(string.lower(obj.Name), "mark") or string.find(string.lower(obj.Name), "death")) then
                marks = marks + 1
            end
        end
        if marks >= 2 then
            useGatling()
            sendNotification("🔥 СЕЙВ ИНФЕРНУСА!", "У него 2 деатмарка! Спасаем гатлингом!")
            return
        end
    end
    local warhead = findEntity("Warhead")
    if warhead then
        local isExploding = warhead:FindFirstChild("Exploding") or warhead:FindFirstChild("Charge") or (warhead:FindFirstChild("Humanoid") and warhead.Humanoid.Health < 500)
        if isExploding then
            useGatling()
            sendNotification("💥 ФИНАЛЬНЫЙ СНОС", "Вархеад взрывается! Добиваем Гатлингом!")
        end
    end
end

-- СКАНИРОВАНИЕ И РАСЧЕТ ТЕКУЩЕЙ ЭФФЕКТИВНОСТИ МАТЧА
local function evaluateCurrentEfficiency()
    if not isAutoMode or isThinking or not matchStartTime then return end
    local base = Workspace:FindFirstChild("Base") or Workspace:FindFirstChild("MainCore") or Workspace:FindFirstChild("Core")
    if not base or not base:FindFirstChild("Humanoid") then return end
    local hpPercent = base.Humanoid.Health / base.Humanoid.MaxHealth
    local ourUnits = findEntity("Trowel", true) + findEntity("Infernus", true) + findEntity("Atari", true) + findEntity("Rail", true)
    local enemyUnits = findEntity("Enemy", true) + findEntity("Cyber", true) + findEntity("Rionhorn", true)
    local currentEfficiency = (hpPercent * 100) + (ourUnits * 10) - (enemyUnits * 15)
    local currentWatchTime = tick() - matchStartTime
    if currentEfficiency > currentRoundMaxEfficiency then
        currentRoundMaxEfficiency = currentEfficiency
        currentRoundBestTime = currentWatchTime
        currentRoundBestStage = currentStage
    end
end

task.spawn(function() while task.wait(1) do pcall(evaluateCurrentEfficiency) end end)

-- ЛОГИКА МУТАЦИИ ДНК И СБРОСА КАТКИ К ЛУЧШЕМУ МОМЕНТУ БОЯ
local function runAIThinkingProcess(stage)
    isThinking = true
    _G.TopBarText.TextColor3 = Color3.fromRGB(254, 154, 0)
    local totalTimeSurvived = tick() - matchStartTime
    sendNotification("🧠 АНАЛИЗ ЛУЧШЕГО МОМЕНТА", "Поиск точки перелома боя и мутации ДНК...")
    if currentRoundMaxEfficiency > _G.AI_Max_Match_Efficiency then
        _G.AI_Max_Match_Efficiency = currentRoundMaxEfficiency
        _G.AI_Best_Moment_Time = currentRoundBestTime
        _G.AI_Best_Moment_Stage = currentRoundBestStage
        _G.AI_Best_Infernus_Offset = _G.Infernus_Timing_Offset
        _G.TopBarText.Text = string.format("🤖 ИИ: Нашел лучший момент на %d-й сек! Запоминаем...", math.floor(_G.AI_Best_Moment_Time))
    else
        _G.TopBarText.Text = "🤖 ИИ: Текущий раунд слабее пика. Откат к лучшей тактике..."
        _G.Infernus_Timing_Offset = _G.AI_Best_Infernus_Offset
    end
    local timeDelta = totalTimeSurvived - currentRoundBestTime
    if timeDelta < 10 then
        ACTION_COOLDOWN = math.max(0.20, ACTION_COOLDOWN - 0.03)
    else
        _G.Infernus_Timing_Offset = _G.Infernus_Timing_Offset + 1.5
    end
    task.wait(3.5)
    currentRoundMaxEfficiency = 0
    currentRoundBestTime = 0
    if RestartRemote and RestartRemote:IsA("RemoteEvent") then
        RestartRemote:FireServer()
    else
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, btn in pairs(pGui:GetDescendants()) do
                if btn:IsA("TextButton") and (string.find(string.lower(btn.Name), "restart") or string.find(string.lower(btn.Text), "retry")) then
                    pcall(function() firesignal(btn.MouseButton1Click) end)
                    break
                end
            end
        end
    end
    isThinking = false
    currentStage = "Investment_4"
    matchStartTime = tick()
end

-- СЛЕЖКА ЗА КРИТИЧЕСКИМ ХП БАЗЫ И НАКОПЛЕНИЕМ СТРЕССА ИИ
local function handleAIDefeat(reason, stressPoints)
    if isThinking then return end
    _G.AI_Total_Stress = _G.AI_Total_Stress + stressPoints
    if _G.AI_Total_Stress >= 15 then
        _G.AI_Total_Stress = 0
        task.spawn(function() runAIThinkingProcess(currentStage) end)
    end
end

task.spawn(function()
    while task.wait(1) do
        if isAutoMode and not isThinking then
            local base = Workspace:FindFirstChild("Base") or Workspace:FindFirstChild("MainCore") or Workspace:FindFirstChild("Core")
            if base and base:FindFirstChild("Humanoid") then
                local hpPercent = base.Humanoid.Health / base.Humanoid.MaxHealth
                if hpPercent < 0.25 then
                    handleAIDefeat("Danger", 2)
                elseif hpPercent < 0.55 then
                    handleAIDefeat("Critical", 5)
                end
            end
        end
    end
end)
